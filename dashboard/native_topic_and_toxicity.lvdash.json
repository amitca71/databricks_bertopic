{
  "datasets": [
    {
      "name": "05ab99f1",
      "displayName": "message_incitement_and_topic",
      "queryLines": [
        "with t_messages as (select id, text, translated, incitement.* from bertopic_input),\n",
        "t_message_topic as (select id, model, timestamp, topic from topics)\n",
        "select * from t_messages inner join t_message_topic using (id)\n",
        "where :model=model \n",
        "and (size(:topic) is null or array_contains(:topic, topic))\n",
        "and (size(:pred_label) is null or array_contains(:pred_label, pred_label))\n"
      ],
      "parameters": [
        {
          "displayName": "model",
          "keyword": "model",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "HDBSCAN"
                }
              ]
            }
          }
        },
        {
          "displayName": "topic",
          "keyword": "topic",
          "dataType": "DECIMAL",
          "complexType": "MULTI",
          "defaultSelection": {
            "operator": {
              "operator": "AND"
            }
          }
        },
        {
          "displayName": "pred_label",
          "keyword": "pred_label",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "operator": {
              "operator": "AND"
            }
          }
        }
      ],
      "catalog": "amit",
      "schema": "bertopic"
    },
    {
      "name": "3f08bbe9",
      "displayName": "Unique Model Names Extracted from Topics",
      "queryLines": [
        "select distinct model from topic_info_local"
      ],
      "catalog": "amit",
      "schema": "bertopic"
    },
    {
      "name": "b11652c0",
      "displayName": "topic_info",
      "queryLines": [
        "select * from v2_topic_info_with_scores_layer_1 \n",
        "where   \n",
        "(size(:full_topic) is null or array_contains(:full_topic, full_topic)) and execution_id = :execution_id\n",
        "order by full_topic"
      ],
      "parameters": [
